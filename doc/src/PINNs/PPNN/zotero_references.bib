@article{lynn2019,
	title = {Quantum {Monte} {Carlo} {Methods} in {Nuclear} {Physics}: {Recent} {Advances}},
	volume = {69},
	issn = {0163-8998, 1545-4134},
	shorttitle = {Quantum {Monte} {Carlo} {Methods} in {Nuclear} {Physics}},
	doi = {10.1146/annurev-nucl-101918-023600},
	abstract = {In recent years, the combination of precise quantum Monte Carlo (QMC) methods with realistic nuclear interactions and consistent electroweak currents, in particular those constructed within effective field theories (EFTs), has led to new insights in light and medium-mass nuclei, neutron matter, and electroweak reactions. For example, with the same chiral interactions, QMC calculations can reproduce binding energies and radii for light nuclei, n–α scattering phase shifts, and the neutron matter equation of state. This compelling new body of work has been made possible both by advances in QMC methods for nuclear physics, which push the bounds of applicability to heavier nuclei and to asymmetric nuclear matter, and by the development of local chiral EFT interactions up to next-to-next-to-leading order and minimally nonlocal interactions including Δ degrees of freedom. In this review, we discuss these recent developments and give an overview of the exciting results for nuclei, neutron matter and neutron stars, and electroweak reactions.},
	language = {english},
	number = {Volume 69, 2019},
	urldate = {2024-07-19},
	journal = {Annual Review of Nuclear and Particle Science},
	publisher = {Annual Reviews},
	author = {Lynn, J. E. and Tews, I. and Gandolfi, S. and Lovato, A.},
	month = oct,
	year = {2019},
	pages = {279--305},
}

