%================================================
\section{From Quantum Mechanics to Gauge Theories}

%------------------------------------------------
\begin{frame}{Starting Point: Many-Body Quantum Mechanics}

We are familiar with:

\[
H = \sum_i \frac{p_i^2}{2m} + V(\{x_i\})
\]

\begin{itemize}
\item Hilbert space grows exponentially
\item Strong correlations require nonperturbative methods
\end{itemize}

Gauge theories generalize this idea to fields.
\end{frame}

%------------------------------------------------
\begin{frame}{What is a Gauge Theory?}

Gauge symmetry:

\[
\psi(x) \rightarrow e^{i\alpha(x)} \psi(x)
\]

Requires introduction of gauge field:

\[
A_\mu \rightarrow A_\mu - \partial_\mu \alpha
\]

Gauge invariance enforces local constraints.

Physical examples:
\begin{itemize}
\item QED
\item QCD
\item Electroweak theory
\end{itemize}
\end{frame}

%------------------------------------------------
\begin{frame}{Why Are Gauge Theories Hard?}

\begin{itemize}
\item Infinite degrees of freedom
\item Nonlinear self-interactions
\item Confinement
\item Chiral symmetry breaking
\end{itemize}

Perturbation theory fails at strong coupling.
\end{frame}

%================================================
\section{Lattice Gauge Theory}

%------------------------------------------------
\begin{frame}{Idea of Lattice Regularization}

Discretize space-time:

\[
x_\mu = n_\mu a
\]

Advantages:
\begin{itemize}
\item UV regulator
\item Finite degrees of freedom
\item Amenable to numerical computation
\end{itemize}
\end{frame}

%------------------------------------------------
\begin{frame}{Path Integral vs Hamiltonian Picture}

Standard lattice QCD:

\[
Z = \int \mathcal{D}U\, e^{-S_E[U]}
\]

Monte Carlo sampling.

Limitations:
\begin{itemize}
\item Sign problem
\item Real-time evolution inaccessible
\item Finite density problematic
\end{itemize}
\end{frame}

%------------------------------------------------
\begin{frame}{The Sign Problem}

If action becomes complex:

\[
e^{-S_E} \notin \mathbb{R}^+
\]

Importance sampling fails.

Occurs in:
\begin{itemize}
\item Finite baryon density
\item $\theta$-vacua
\item Real-time dynamics
\end{itemize}

Motivation for quantum simulation.
\end{frame}

%================================================
\section{Quantum Computing Basics}

%------------------------------------------------
\begin{frame}{What Is a Quantum Computer?}

Hilbert space:

\[
\mathcal{H} = (\mathbb{C}^2)^{\otimes N}
\]

Dimension:
\[
2^N
\]

Unitary evolution:
\[
|\psi\rangle \rightarrow U |\psi\rangle
\]

Quantum computers naturally simulate Hamiltonian dynamics.
\end{frame}

%------------------------------------------------
\begin{frame}{Digital Quantum Simulation}

Trotterization:

\[
e^{-i(H_A + H_B)t}
\approx
\left(e^{-iH_A \delta t} e^{-iH_B \delta t}\right)^M
\]

Quantum circuits approximate time evolution.
\end{frame}

%================================================
\section{The Schwinger Model}

%------------------------------------------------
\begin{frame}{Classical example: Why the Schwinger Model?}

1+1 dimensional QED.

Contains:
\begin{itemize}
\item Confinement
\item Massive boson
\item $\theta$-dependence
\end{itemize}

Simplest nontrivial gauge theory.
\end{frame}

%------------------------------------------------
\begin{frame}{Continuum Lagrangian}

\[
\mathcal{L}
=
-\frac14 F_{\mu\nu}F^{\mu\nu}
+ i\bar\psi\gamma^\mu D_\mu\psi
- m\bar\psi e^{i\theta\gamma_5}\psi
\]

Gauss law constraint:

\[
\partial_x E = g \psi^\dagger \psi
\]
\end{frame}

%================================================
\section{From Fields to Qubits}

%------------------------------------------------
\begin{frame}{Discretization}

Spatial lattice:
\[
x_n = n a
\]

Use staggered fermions.

Gauge fields on links.

Gauss law allows elimination of gauge variables.
\end{frame}

%------------------------------------------------
\begin{frame}{Resulting Spin Hamiltonian}

After Jordan–Wigner:

\[
H = H_{ZZ} + H_{\pm} + H_Z
\]

Features:

\begin{itemize}
\item Long-range interactions
\item Nearest-neighbor hopping
\item Mass terms
\end{itemize}
\end{frame}

%------------------------------------------------
\begin{frame}{Nonlocal Interaction Term}

Gauss law elimination yields:

\[
H_{ZZ}
=
\frac{J}{2}
\sum_{n=2}^{N-1}
\sum_{k<l\le n}
Z_k Z_l
\]

This term scales quadratically with system size.
\end{frame}

%================================================
\section{Continuum Limit}

%------------------------------------------------
\begin{frame}{Continuum Scaling}

Couplings:

\[
w = \frac{1}{2a}, \quad
J = \frac{g^2 a}{2}
\]

As:
\[
a \to 0
\]

\begin{itemize}
\item Hopping diverges
\item Gap shrinks
\end{itemize}
\end{frame}

%------------------------------------------------
\begin{frame}{Adiabatic Time Scaling}

Adiabatic condition:

\[
T \gg \frac{1}{\Delta^2}
\]

If:
\[
\Delta \to 0
\]

Then:
\[
T \to \infty
\]

Continuum limit challenging for adiabatic algorithms.
\end{frame}

%================================================
\section{State Preparation Algorithms}

%------------------------------------------------
\begin{frame}{Adiabatic State Preparation}

Interpolate:

\[
H(s) = (1-s)H_0 + sH
\]

Gate count per Trotter step:

\[
N_{\text{CNOT}} \sim (N-1)(N-2)
\]

Quadratic scaling.
\end{frame}

%------------------------------------------------
\begin{frame}{Quantum Approximate Optimization Algorithm}

Variational ansatz:

\[
|\psi_M\rangle
=
\prod_{k=1}^M
e^{-i\beta_k H_0}
e^{-i\gamma_k H}
|\psi_0\rangle
\]

Small $M$ sufficient.
\end{frame}

%------------------------------------------------
\begin{frame}{Blocked QAOA}

Use simplified Hamiltonian in early layers.

Full nonlocal term only once.

Reduces effective depth.
\end{frame}


